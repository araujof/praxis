# == CPEX policy document ==
plugin_settings:
  routing_enabled: true
plugins: []
routes:
- tool: '*'
  policy:
  - require(false)

# == Praxis filter block ==
filter: policy
config_path: /etc/praxis/apikey-opa-cpex-policy.yaml
enforcement: http

