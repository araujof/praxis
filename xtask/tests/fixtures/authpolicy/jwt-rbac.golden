# == CPEX policy document ==
plugin_settings:
  routing_enabled: true
plugins:
- name: keycloak-jwt
  kind: identity/jwt
  hooks:
  - identity.resolve
  on_error: fail
  config:
    header: Authorization
    trusted_issuers:
    - issuer: https://keycloak.example.com/realms/myrealm
      algorithms:
      - RS256
      - ES256
      decoding_key:
        kind: jwks_url
        url: https://keycloak.example.com/realms/myrealm
    claim_mapper: standard
routes:
- tool: '*'
  identity:
  - keycloak-jwt
  when: (!http.path.startsWith('/public'))
  policy:
  - require(!((http.method == 'GET')) || ((('admin' in claim.realm_access.roles)) && (claim.email_verified)))
  - require(!(((http.method == 'POST') || (http.method == 'DELETE'))) || ((('admin' in claim.realm_access.roles))))

# == Praxis filter block ==
filter: policy
config_path: /etc/praxis/jwt-rbac-cpex-policy.yaml
enforcement: http

