# == CPEX policy document ==
plugin_settings:
  routing_enabled: true
plugins:
- name: jwt-internal
  kind: identity/jwt
  hooks:
  - identity.resolve
  on_error: fail
  config:
    header: Authorization
    trusted_issuers:
    - issuer: ''
      algorithms:
      - RS256
      - ES256
      decoding_key:
        kind: jwks_url
        url: https://sso.internal.example.com/jwks
    claim_mapper: standard
routes:
- tool: '*'
  identity:
  - jwt-internal
  when: (http.host.endsWith('.internal.example.com'))
  policy:
  - require(((claim.email_verified == true)))

# == Praxis filter block ==
filter: policy
config_path: /etc/praxis/gateway-defaults-cpex-policy.yaml
enforcement: http

